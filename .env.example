# API Keys - Copy this to .env and fill in your keys
# Only one API key provider is required. The experimental codex provider
# uses `scagent login chatgpt` / `codex login` instead of an API key.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Groq (fast & cheap open-source models)
GROQ_API_KEY=

# Default provider: anthropic, openai, groq, or codex
SCAGENT_PROVIDER=openai

# Default model (optional - uses sensible defaults if not set)
# Examples:
#   anthropic: claude-sonnet-4-20250514
#   openai: gpt-5.4-mini
#   groq: llama-3.3-70b-versatile
#   codex: leave SCAGENT_MODEL unset; optionally set SCAGENT_CODEX_MODEL
SCAGENT_MODEL=gpt-5.4-mini

# Codex provider (experimental; uses ChatGPT/Codex login, not API billing)
# Run first: scagent login chatgpt
# Codex uses SCAGENT_CODEX_MODEL first, then falls back to SCAGENT_MODEL above.
# Leave both unset to use the Codex CLI default for your ChatGPT account/plan.
# SCAGENT_CODEX_MODEL=gpt-5.4

# Custom base URL for OpenAI-compatible APIs (Together AI, OpenRouter, etc.)
# SCAGENT_BASE_URL=https://api.together.xyz/v1

# Tavily Search (recommended - primary backend for web_search_docs)
# Get a key from: https://tavily.com/
TAVILY_API_KEY=

# Google Custom Search / Programmable Search (optional backup for web_search_docs)
# Get these from: https://developers.google.com/custom-search/v1/overview
# Free tier: 100 queries/day
# Search scope depends on your Programmable Search Engine configuration (GOOGLE_CX)
GOOGLE_API_KEY=
GOOGLE_CX=

# ============================================================
# AVAILABLE MODELS (April 2026)
# ============================================================
#
# GROQ MODELS (fast & cheap):
# ---------------------------
# Best for tool calling:
#   llama-3.3-70b-versatile    - Recommended for scagent
#   llama-3.1-70b-versatile    - Also very good
#   llama-3.1-8b-instant       - Faster, but less reliable for tools
#
# Other models on Groq:
#   qwen-qwq-32b               - Reasoning focused (not ideal for tools)
#   deepseek-r1-distill-llama-70b - Reasoning model
#
# OPENAI MODELS:
# --------------
# Flagship:
#   gpt-5.4           - Latest flagship, best for complex reasoning & coding
#   gpt-5.4-pro       - Extra compute for harder problems (via Responses API)
#   gpt-5.4-mini      - GPT-5.4 class, faster/cheaper for high-volume
#   gpt-5.4-nano      - Fastest/cheapest for simple high-volume tasks
#
# Previous Gen (still supported):
#   gpt-4o            - Multimodal (text + audio), good for voice apps
#   gpt-4o-mini       - Faster/cheaper gpt-4o
#   gpt-4-turbo       - Previous generation
#
# Reasoning:
#   o3-mini           - Small reasoning model for science/math/coding
#
# ANTHROPIC MODELS:
# -----------------
# Claude 4.6 (Latest):
#   claude-opus-4-6-20260204      - Most capable, sophisticated reasoning
#   claude-sonnet-4-6-20260XXX    - Balanced performance (check docs for date)
#
# Claude 4.5:
#   claude-opus-4-5-20251101      - Previous flagship
#   claude-sonnet-4-5-20250929    - Great for coding, agents, computer use
#   claude-haiku-4-5-20251001     - Fastest, best for scale/efficiency
#
# Claude 4:
#   claude-sonnet-4-20250514      - Default, solid all-around
#   claude-opus-4-20250514        - Previous Opus
#

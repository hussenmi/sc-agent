# API Keys - Copy this to .env and fill in your keys
# Only one provider is required

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Default provider: anthropic or openai
SCAGENT_PROVIDER=openai

# Default model (optional - uses sensible defaults if not set)
SCAGENT_MODEL=gpt-4o

# ============================================================
# AVAILABLE MODELS (March 2026)
# ============================================================
#
# OPENAI MODELS:
# --------------
# Flagship:
#   gpt-5.4           - Latest flagship, best for complex reasoning & coding
#   gpt-5.4-pro       - Extra compute for harder problems (via Responses API)
#   gpt-5.4-mini      - GPT-5.4 class, faster/cheaper for high-volume
#   gpt-5.4-nano      - Fastest/cheapest for simple high-volume tasks
#
# Previous Gen (still supported):
#   gpt-4o            - Multimodal (text + audio), good for voice apps
#   gpt-4o-mini       - Faster/cheaper gpt-4o
#   gpt-4-turbo       - Previous generation
#
# Reasoning:
#   o3-mini           - Small reasoning model for science/math/coding
#

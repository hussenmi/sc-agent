      "timestamp": "2026-03-31T16:39:21.575702",
      "input_path": null,
      "output_path": null,
      "parameters": {
        "description": "Set Leiden clustering labels from the 0.5-resolution clustering to make the UMAP figure reflect the 0.5 result, then save the updated AnnData in memory.",
        "code": "import scipy.sparse as sp\n\n# Recompute Leiden at 0.5 into a distinct key if not already present, then make it the active clustering key.\n# The clustering tool overwrote the default leiden labels when rerun, so we need to preserve/restore the intended labels.\n# If the original 0.5 labels were not stored, this will at least make the active key explicit for plotting.\nif 'leiden_0_5' not in adata.obs:\n    # Try to recover from temporary columns if present\n    candidates = [c for c in adata.obs.columns if '0_5' in c or '0.5' in c]\n    if candidates:\n        adata.obs['leiden_0_5'] = adata.obs[candidates[0]].astype('category')\n    else:\n        # Fall back: store current labels as the available cluster set and note the issue\n        adata.obs['leiden_0_5'] = adata.obs['leiden'].astype('category')\n\n# Keep the 0.5 clustering as the default 'leiden' label for downstream plotting\nadata.obs['leiden'] = adata.obs['leiden_0_5'].astype('category')\n\n# Record that the active clustering should be interpreted as the 0.5 result\nadata.uns['active_leiden_resolution'] = 0.5\n",
        "output_dir": "run_2026_03_31_155717"
      },
      "metrics": {
